{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["ES2017"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": "./miniprogram",
    "types": ["miniprogram-api-typings"]
  },
  "include": ["./miniprogram/**/*.ts"],
  "exclude": ["node_modules", "cloudfunctions"]
}
