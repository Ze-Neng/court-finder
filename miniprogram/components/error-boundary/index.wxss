.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
  padding: 60rpx 48rpx;
  box-sizing: border-box;
}

.error-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.error-message {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.error-btn {
  padding: 16rpx 56rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: #07c160;
  border: none;
  border-radius: 40rpx;
  line-height: 1.4;
}
