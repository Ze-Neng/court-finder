/* ====== 筛选栏 ====== */
.filter-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 32rpx;
}

.filter-chip.active {
  color: #fff;
  background: #07c160;
}

.filter-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.mode-toggle {
  font-size: 36rpx;
  padding: 4rpx 8rpx;
}

.filter-btn {
  font-size: 24rpx;
  color: #333;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.filter-btn.active {
  color: #07c160;
}

/* ====== 地图 ====== */
.map-container {
  position: relative;
  height: calc(100vh - 88rpx);
}

.home-map {
  width: 100%;
  height: 100%;
}

/* ====== 底部卡片面板 ====== */
.bottom-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
}

.card-swiper {
  height: 180rpx;
}

.court-card {
  margin: 0 20rpx;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.card-type {
  font-size: 22rpx;
  color: #999;
}

.card-dist {
  font-size: 22rpx;
  color: #666;
  margin-left: auto;
}

.card-reason {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 定位提示条 */
.location-hint {
  text-align: center;
  padding: 12rpx;
  font-size: 24rpx;
  color: #07c160;
  background: #fff;
  border-top: 1rpx solid #eee;
}

/* ====== 列表模式 ====== */
.list-container {
  height: calc(100vh - 88rpx);
}

.court-list {
  height: 100%;
  padding: 0 24rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-body {
  flex: 1;
  overflow: hidden;
}

.list-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.list-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.list-type {
  font-size: 22rpx;
  color: #999;
}

.list-reason {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-dist-col {
  font-size: 26rpx;
  color: #666;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.list-arrow {
  font-size: 36rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* ====== 筛选抽屉 ====== */
.filter-overlay {
  display: none;
}

.filter-overlay.show {
  display: block;
}

.filter-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(0,0,0,0.4);
}

.filter-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 101;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 32rpx calc(env(safe-area-inset-bottom) + 32rpx);
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.filter-title {
  font-size: 32rpx;
  font-weight: 600;
}

.filter-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.filter-section {
  margin-bottom: 32rpx;
}

.filter-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.chip-active {
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  font-weight: 500;
}

.chip-go {
  border-left: 4rpx solid transparent;
}

.chip-caution.chip-active {
  color: #fa9d3b;
  background: rgba(250, 157, 59, 0.1);
}

.chip-stop.chip-active {
  color: #ee3f3f;
  background: rgba(238, 63, 63, 0.1);
}

.filter-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.filter-btn-reset {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 44rpx;
}

.filter-btn-apply {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #fff;
  background: #07c160;
  border-radius: 44rpx;
}
