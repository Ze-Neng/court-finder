/* 通用骨架块 */
.sk-block {
  background: linear-gradient(90deg, #e8e8e8 25%, #f0f0f0 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
}

.sk-line {
  height: 24rpx;
  background: linear-gradient(90deg, #e8e8e8 25%, #f0f0f0 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}

.sk-line--title { width: 70%; height: 32rpx; }
.sk-line--short { width: 40%; }
.sk-line--md { width: 90%; }
.sk-line--lg { width: 60%; height: 40rpx; margin-bottom: 24rpx; }

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 卡片骨架 */
.skeleton-card {
  padding: 24rpx;
}
.sk-card-img {
  width: 100%;
  height: 300rpx;
  margin-bottom: 20rpx;
}

/* 列表骨架 */
.sk-list-item {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}
.sk-list-left {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}
.sk-list-right {
  flex: 1;
  padding-top: 8rpx;
}

/* 详情骨架 */
.skeleton-detail {
  padding: 24rpx;
}
.sk-detail-hero {
  width: 100%;
  height: 400rpx;
  margin-bottom: 32rpx;
}
