.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
  padding: 60rpx 48rpx;
  box-sizing: border-box;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  text-align: center;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.empty-btn {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #07c160;
  background: transparent;
  border: 2rpx solid #07c160;
  border-radius: 40rpx;
  line-height: 1.4;
}
